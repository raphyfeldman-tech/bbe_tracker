<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>BEE Tracker — Validation Report</title>
  <style>
    body { font-family: -apple-system, system-ui, sans-serif; padding: 2em; color: #111; }
    h1 { margin-bottom: 0.5em; }
    .summary { display: flex; gap: 1em; margin-bottom: 1.5em; }
    .count { padding: 0.75em 1em; border-radius: 4px; min-width: 90px; text-align: center; }
    .count.error { background: #F8CBAD; }
    .count.warning { background: #FFE699; }
    .count.info { background: #D9E1F2; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ccc; padding: 0.4em 0.6em; text-align: left; vertical-align: top; }
    tr.error { background: #FFF3F0; }
    tr.warning { background: #FFF9E6; }
    tr.info { background: #F2F6FC; }
  </style>
</head>
<body>
  <h1>Validation Report</h1>
  <div class="summary">
    <div class="count error">Errors: {{ counts.error }}</div>
    <div class="count warning">Warnings: {{ counts.warning }}</div>
    <div class="count info">Info: {{ counts.info }}</div>
  </div>
  <table>
    <thead>
      <tr><th>Severity</th><th>Sheet</th><th>Row</th><th>Message</th></tr>
    </thead>
    <tbody>
      {% for f in findings %}
      <tr class="{{ f.severity.value }}">
        <td>{{ f.severity.value|upper }}</td>
        <td>{{ f.sheet or '—' }}</td>
        <td>{{ f.row or '—' }}</td>
        <td>{{ f.message }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
